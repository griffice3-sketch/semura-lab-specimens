
//====================================================================
//  検体018 ‑ 簡略化ロジック（Semura Lab 診断用抜粋）
//--------------------------------------------------------------------
//  ※本コードは診断カルテ用に「エントリー判定部のみ」を抽出・簡略化した
//    疑似ロジックである。著作権表記・作成者情報・約定処理・
//    ブローカー適合処理（ロット正規化/証拠金/フィリング/セッション）
//    は診断に不要なため除去した。
//  ※これは実運用EAではない。そのままでは動作せず、実践使用は不可。
//  ※ロジックの優劣を論評する目的ではなく、あくまで診断の「検体」として
//    構造を提示するものである。
//====================================================================

// --- 診断対象パラメータ（抜粋） ---
// TF        = H1
// ADX(14)   > 25 かつ 上昇中
// EMA(20)   への価格回帰をATR比で判定
// ATR(14)   SL = ATR×1.5 / TP = SL×2.0（RR 2:1）
// 単一ポジションのみ・固定ロット

// --- シグナル生成（診断に用いた中核部のみ） ---
int ComputeSignal()
{
    // 確定足 [1]=直近確定, [2]=その1本前 のみ参照（未来参照なし）
    double adx1, adx2;      // ADX main [1],[2]
    double diP,  diM;       // +DI, -DI [1]
    double ema1, ema2;      // EMA20 [1],[2]
    double atr1, atr2;      // ATR14 [1],[2]
    double close1, close2;  // 終値 [1],[2]
    // ↑ 各値は指標バッファから取得（取得処理は簡略化のため省略）

    // 1) トレンドフィルター：ADXが閾値超 かつ 上昇中
    if(!(adx1 > 25.0 && adx1 > adx2)) return 0;

    // 2) EMA回帰イベント：前々足で乖離 → 直近足で接近
    double dist1 = MathAbs(close1 - ema1) / atr1;
    double dist2 = MathAbs(close2 - ema2) / atr2;
    if(!(dist1 < 0.5 && dist2 >= 0.5)) return 0;

    // 3) 方向決定：DIの大小のみ
    if(diP > diM) return  1;   // BUY
    if(diM > diP) return -1;   // SELL
    return 0;
}

// --- 発注イメージ（診断確認用の骨格のみ） ---
// if(新バー && ポジション0 && signal!=0){
//     slDistance = atr1 * 1.5;
//     tpDistance = slDistance * 2.0;
//     → 成行1発、SL/TP同時設定（ナンピン/マーチンなし）
// }
//====================================================================
//  【診断メモ】抽出範囲＝トレンド判定／EMA回帰判定／方向判定／
//   RR設定／単一ポジション制御。スプレッド・時間帯フィルターは
//   原検体に存在せず、抽出対象なし（診断カルテ本文参照）。
//====================================================================
